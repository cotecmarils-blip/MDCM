# Variables opcionales para el servicio Django en Railway (mdcm-production)
# CORS ya permite *.up.railway.app por defecto en config/settings.py
# FRONTEND_URL=https://TU-FRONTEND.up.railway.app
DEBUG=False

# Persistencia de fotos/documentos: montar un volumen en Railway en /data/media
# y definir MEDIA_ROOT para que los archivos sobrevivan a redeploys.
# MEDIA_ROOT=/data/media

# Variables para el servicio React en Railway (Root Directory: frontend)
# REACT_APP_API_ROOT está en frontend/.env.production → https://mdcm-production.up.railway.app
# Nota: MCDM-production.up.railway.app ya no responde (404).
