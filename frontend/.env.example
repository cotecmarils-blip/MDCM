# Backend root URL (without /api). Used at build time for production.
# Production (Railway):
# REACT_APP_API_ROOT=https://MCDM-production.up.railway.app
REACT_APP_API_ROOT=http://127.0.0.1:8000

# Alternative: full API base URL (with /api suffix)
# REACT_APP_API_URL=https://MCDM-production.up.railway.app/api
